// Mô hình thiết kế database ->  BRAC: Role-Based Access Control - Kiểm soát truy cập dựa trên vai trò

generator client {
  provider = "prisma-client-js"
}

generator json {
  provider = "prisma-json-types-generator"
}

generator zod {
  provider           = "zod-prisma-types"
  output             = "../src/generated/zod"
  useTypesAssertions = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────────

enum UserStatus {
  active
  inactive
}

enum VendorStatus {
  active
  inactive
}

enum RoleType {
  SUPER_ADMIN
  SYSTEM
  VENDOR
}

enum UserSystemRoleStatus {
  active
  inactive
}

enum UserVendorRoleStatus {
  active
  inactive
}

enum ProductStatus {
  active
  inactive
  draft
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum AddressType {
  billing
  shipping
}

enum PromotionStatus {
  active
  inactive
  expired
}

enum PromotionType {
  percentage
  fixed_amount
  free_shipping
  buy_x_get_y
}

// ── MODELS ────────────────────────────────────────────────────

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String
  firstName   String?
  lastName    String?
  fullAddress String?
  city        String?
  province    String?
  country     String?
  phone       String?
  status      UserStatus @default(active)
  createdAt   DateTime   @default(now())
  createdBy   String?
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  vendors         Vendor[]
  userSystemRoles UserSystemRole[] // (user có role hệ thống)
  userVendorRoles UserVendorRole[] // (user tham gia nhiều vendor với role khác nhau)
  orders          Order[]
  cart            Cart?
}

model Vendor {
  id            String       @id @default(uuid())
  userID        String
  name          String
  slug          String       @unique
  description   String?
  logoUrl       String?
  taxCode       String?
  totalProducts Int          @default(0)
  totalOrders   Int          @default(0)
  status        VendorStatus @default(active)
  createdAt     DateTime     @default(now())
  createdBy     String?
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  user            User             @relation(fields: [userID], references: [id])
  products        Product[]
  userVendorRoles UserVendorRole[] // (danh sách thành viên trong vendor)
}

model Role {
  id          String   @id @default(uuid())
  name        String   
  description String?
  roleType    RoleType @default(VENDOR)
  createdAt   DateTime @default(now())
  createdBy   String?
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  userSystemRoles UserSystemRole[]
  userVendorRoles UserVendorRole[]
  rolePermissions RolePermission[]

  @@unique([name])
}

model Permission {
  id                 String    @id @default(uuid())
  name               String
  description        String?
  // [route]_[action] (Ex: [/products]_[read], [/products]_[create])
  key                String // (dùng để check permission trong code)
  isSystemPermission Boolean   @default(false)
  createdAt          DateTime  @default(now())
  createdBy          String?
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  rolePermissions RolePermission[]

  @@unique([name, key])
}

model RolePermission {
  roleID       String
  permissionID String
  createdAt    DateTime @default(now())
  createdBy    String?

  role       Role       @relation(fields: [roleID], references: [id])
  permission Permission @relation(fields: [permissionID], references: [id])

  @@id([roleID, permissionID])
}

model UserSystemRole {
  id        String               @id @default(uuid())
  userID    String
  roleID    String
  status    UserSystemRoleStatus @default(active)
  createdAt DateTime             @default(now())
  createdBy String?

  user User @relation(fields: [userID], references: [id])
  role Role @relation(fields: [roleID], references: [id])

  @@unique([userID, roleID]) // (1 user có thể có nhiều system role)
}

model UserVendorRole {
  id        String               @id @default(uuid())
  userID    String
  vendorID  String
  roleID    String
  status    UserVendorRoleStatus @default(active)
  createdAt DateTime             @default(now())
  createdBy String?

  user   User   @relation(fields: [userID], references: [id])
  vendor Vendor @relation(fields: [vendorID], references: [id])
  role   Role   @relation(fields: [roleID], references: [id])

  @@unique([userID, vendorID]) // (1 user chỉ có 1 role trong 1 vendor)
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  parentID    String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  parent            Category?         @relation("CategoryParent", fields: [parentID], references: [id])
  children          Category[]        @relation("CategoryParent")
  productCategories ProductCategory[]
}

model Product {
  id            String        @id @default(uuid())
  vendorID      String
  name          String
  slug          String
  description   String?
  sku           String?       @unique
  price         Decimal
  stockQuantity Int           @default(0)
  status        ProductStatus @default(draft)
  createdAt     DateTime      @default(now())
  createdBy     String?
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  vendor            Vendor            @relation(fields: [vendorID], references: [id])
  productCategories ProductCategory[]
  productImages     ProductImage[]
  productVariants   ProductVariant[]

  @@unique([vendorID, slug])
}

model ProductVariant {
  id            String    @id @default(uuid())
  productID     String
  name          String?
  sku           String?   @unique
  price         Decimal
  stockQuantity Int       @default(0)
  attributes    Json?
  createdAt     DateTime  @default(now())
  createdBy     String?
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  product       Product        @relation(fields: [productID], references: [id])
  productImages ProductImage[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
}

model ProductCategory {
  productID  String
  categoryID String

  product  Product  @relation(fields: [productID], references: [id])
  category Category @relation(fields: [categoryID], references: [id])

  @@id([productID, categoryID])
}

model ProductImage {
  id               String    @id @default(uuid())
  name             String
  description      String?
  productID        String? // (ảnh thuộc product gốc)
  productVariantID String? // (ảnh thuộc variant)
  imageUrl         String
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  createdBy        String?
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  product        Product?        @relation(fields: [productID], references: [id])
  productVariant ProductVariant? @relation(fields: [productVariantID], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  orderNumber    String      @unique
  userID         String
  status         OrderStatus @default(pending)
  subtotal       Decimal
  taxAmount      Decimal     @default(0)
  shippingAmount Decimal     @default(0)
  discountAmount Decimal     @default(0)
  totalAmount    Decimal
  currency       String      @default("VND")
  notes          String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime    @default(now())
  createdBy      String?
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  user            User             @relation(fields: [userID], references: [id])
  orderItems      OrderItem[]
  orderAddresses  OrderAddress[]
  orderPromotions OrderPromotion[]
  // payments        Payment[]
}

model OrderItem {
  id                     String  @id @default(uuid())
  orderID                String
  productVariantID       String
  quantity               Int
  unitPrice              Decimal
  totalPrice             Decimal
  productVariantSnapshot Json?

  productVariant ProductVariant @relation(fields: [productVariantID], references: [id])
  order          Order          @relation(fields: [orderID], references: [id])
}

model OrderAddress {
  id          String      @id @default(uuid())
  orderID     String
  type        AddressType
  firstName   String
  lastName    String?
  company     String?
  fullAddress String
  city        String?
  province    String?
  country     String?
  phone       String

  order Order @relation(fields: [orderID], references: [id])
}

model Promotion {
  id          String          @id @default(uuid())
  code        String          @unique
  name        String
  description String?
  type        PromotionType
  value       Decimal
  usageLimit  Int?
  startDate   DateTime        @default(now())
  endDate     DateTime?
  status      PromotionStatus @default(inactive)
  createdAt   DateTime        @default(now())
  createdBy   String?
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  
  orderPromotions OrderPromotion[]
}

model OrderPromotion {
  id             String  @id @default(uuid())
  orderID        String
  promotionID    String
  discountAmount Decimal @default(0)

  order     Order     @relation(fields: [orderID], references: [id])
  promotion Promotion @relation(fields: [promotionID], references: [id])

  @@unique([orderID, promotionID])
}

model Cart {
  id        String   @id @default(uuid())
  userID    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userID], references: [id])
  cartItems CartItem[]
}

model CartItem {
  id               String   @id @default(uuid())
  cartID           String
  productVariantID String
  quantity         Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cart           Cart           @relation(fields: [cartID], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantID], references: [id])

  @@unique([cartID, productVariantID])
}

