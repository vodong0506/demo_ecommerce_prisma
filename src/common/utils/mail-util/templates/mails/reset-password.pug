doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Reset your password

    style.
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: #ffffff;
        font-family: Google Sans, Roboto, Arial, sans-serif;
        font-size: 14px;
        color: #3c4043;
        line-height: 1.6;
      }

      .wrapper {
        max-width: 600px;
        margin: 48px auto;
        padding: 0 24px;
      }

      .brand {
        font-size: 14px;
        font-weight: 600;
        color: #6750a4;
        margin-bottom: 16px;
      }

      h1 {
        font-size: 24px;
        font-weight: 700;
        color: #1f1f1f;
        margin-bottom: 20px;
      }

      p {
        margin-bottom: 14px;
        color: #3c4043;
      }

      .divider {
        border: none;
        border-top: 1px solid #e8eaed;
        margin: 16px 0;
      }

      .user-row {
        padding: 14px 0;
        font-size: 14px;
        color: #3c4043;
      }

      .user-row strong {
        color: #1f1f1f;
      }

      .link {
        color: #6750a4;
        text-decoration: underline;
        font-size: 14px;
      }

      .footer-note {
        margin-top: 32px;
        font-size: 14px;
        color: #3c4043;
      }

  body
    .wrapper
      .brand VTDhub

      h1 Reset your password

      p Hello #{username},

      p Someone requested a new password for the following account on VTDhub:

      hr.divider

      .user-row
        | Username: #[strong #{username}]

      hr.divider

      p
        | If you did not make this request, you can safely ignore this email.
        | If you'd like to continue, reset your password via the link below:

      a.link(href=resetLink) Reset your password

      p.footer-note Thanks for reading.