doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Reset Password
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { background: #f4f6fb; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
      .wrapper { max-width: 480px; margin: 40px auto; background: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0; }
      .header { background: #1a1a2e; padding: 32px; text-align: center; }
      .logo { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 24px; }
      .logo-icon { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; }
      .logo-icon img { width: 100%; height: 100%; object-fit: contain; border-radius: 8px; }
      .logo-text { font-size: 15px; font-weight: 600; color: #e8eaf6; letter-spacing: 0.02em; }
      .icon-circle { width: 64px; height: 64px; border-radius: 50%; background: rgba(79,142,247,0.15); border: 1.5px solid rgba(79,142,247,0.35); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
      .header h1 { font-size: 20px; font-weight: 500; color: #e8eaf6; margin-bottom: 4px; }
      .header p  { font-size: 13px; color: rgba(232,234,246,0.5); }
      .body  { padding: 32px; }
      .body p  { font-size: 14px; color: #4a5568; line-height: 1.7; margin-bottom: 16px; }
      .btn-wrap { text-align: center; margin: 24px 0; }
      .btn { display: inline-block; background: #4f8ef7; color: #ffffff !important; font-size: 14px; font-weight: 500; padding: 12px 32px; border-radius: 8px; text-decoration: none; letter-spacing: 0.02em; }
      .notice { background: #f7faff; border-radius: 8px; padding: 12px 14px; margin: 24px 0; display: flex; gap: 10px; }
      .notice svg { flex-shrink: 0; margin-top: 2px; }
      .notice p { font-size: 13px; color: #718096; margin: 0; }
      .notice strong { color: #2d3748; font-weight: 500; }
      .fallback { font-size: 13px; color: #718096; }
      .fallback-link { display: block; font-size: 12px; color: #4f8ef7; word-break: break-all; background: #f7faff; padding: 10px 12px; border-radius: 8px; margin-top: 8px; font-family: monospace; }
      .footer { border-top: 1px solid #e2e8f0; padding: 20px 32px; text-align: center; }
      .footer p { font-size: 12px; color: #a0aec0; margin-bottom: 4px; }
      .footer a { color: #4f8ef7; text-decoration: none; }
      .footer small { font-size: 11px; color: #cbd5e0; }

  body
    .wrapper
      .header
        .logo
          .logo-icon
            img(src="cid:vtdhub-logo" alt="VTDhub Logo")
          span.logo-text VTDhub

        .icon-circle
          svg(width="28" height="28" fill="none" stroke="#4f8ef7" stroke-width="1.8" viewBox="0 0 24 24")
            rect(x="3" y="11" width="18" height="11" rx="2")
            path(d="M7 11V7a5 5 0 019.9-1")

        h1 Reset your password
        p Request received at #{sentAt}

      .body
        p Hi there,
        p
          | We received a request to reset the password for your account.
          | Click the button below to choose a new password.

        .btn-wrap
          a.btn(href= redirectTo, target="_blank") Reset Password

        .notice
          svg(width="16" height="16" fill="none" stroke="#718096" stroke-width="2" viewBox="0 0 24 24")
            circle(cx="12" cy="12" r="10")
            line(x1="12" y1="8" x2="12" y2="12")
            line(x1="12" y1="16" x2="12.01" y2="16")
          p
            | This link expires in&nbsp;
            strong 24 hours
            | . If you didn't request this, you can safely ignore this email.

        p.fallback Or paste this link into your browser: 
        a.fallback-link(
          href="http://localhost:8888/api/auth/reset-password",
          target="_blank"
      )

      .footer
        p
          | Need help?&nbsp;
          a(href="mailto:support@vtdhub.com") support@vtdhub.com
        small © 2026 VTDhub · All rights reserved